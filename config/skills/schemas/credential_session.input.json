{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "credential_session.input",
  "type": "object",
  "required": ["operation"],
  "properties": {
    "operation": { "type": "string", "enum": ["store", "get", "list", "revoke"] },
    "session_id": { "type": "string" },
    "kind": { "type": "string", "enum": ["cookie", "bearer", "evilginx", "ssh_key_ref", "vpn_profile"] },
    "label": { "type": "string" },
    "value_ref": { "type": "string", "description": "Vault pointer — never raw secret in JSON" },
    "metadata": { "type": "object" }
  }
}
