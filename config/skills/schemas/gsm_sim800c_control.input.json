{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "gsm_sim800c_control.input",
  "description": "High-level GSM lab operations — maps to AT commands in worker agent",
  "type": "object",
  "required": ["action"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["GSM_SEND", "GSM_RECV", "GSM_USSD", "GSM_POWER", "GSM_LOG", "GSM_STATUS"]
    },
    "device_id": { "type": "string", "default": "sim800c-0", "description": "Serial port or device ref" },
    "GSM_SEND": {
      "type": "object",
      "properties": {
        "destination": { "type": "string", "description": "E.164 phone number" },
        "text": { "type": "string", "maxLength": 160 },
        "encoding": { "type": "string", "enum": ["gsm7", "ucs2"], "default": "gsm7" }
      }
    },
    "GSM_RECV": {
      "type": "object",
      "properties": {
        "timeout_sec": { "type": "integer", "default": 30 },
        "delete_after_read": { "type": "boolean", "default": true }
      }
    },
    "GSM_USSD": {
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "e.g. *100#" }
      }
    },
    "GSM_POWER": {
      "type": "object",
      "properties": {
        "state": { "type": "string", "enum": ["on", "off", "reset"] }
      }
    },
    "GSM_LOG": {
      "type": "object",
      "properties": {
        "since": { "type": "string", "format": "date-time" },
        "limit": { "type": "integer", "default": 100 }
      }
    },
    "authorization_ref": { "type": "string" }
  }
}
