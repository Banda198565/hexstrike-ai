{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "scatter_gather.output",
  "type": "object",
  "required": ["task_id", "results", "merged"],
  "properties": {
    "task_id": { "type": "string" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["group_id", "skill_id", "status", "output"],
        "properties": {
          "group_id": { "type": "integer" },
          "skill_id": { "type": "string" },
          "status": { "type": "string", "enum": ["success", "failed", "timeout"] },
          "output": { "type": "object" },
          "latency_ms": { "type": "number" },
          "artifact_ref": { "type": "string" }
        }
      }
    },
    "merged": { "type": "object", "description": "Unified structure for R1 next planning turn" },
    "failures": { "type": "array", "items": { "type": "string" } }
  }
}
