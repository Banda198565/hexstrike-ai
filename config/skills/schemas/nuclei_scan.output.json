{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nuclei_scan.output",
  "type": "object",
  "required": ["success", "findings"],
  "properties": {
    "success": { "type": "boolean" },
    "scan_id": { "type": "string" },
    "target": { "type": "string" },
    "finding_count": { "type": "integer" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "template_id": { "type": "string" },
          "name": { "type": "string" },
          "severity": { "type": "string" },
          "host": { "type": "string" },
          "matched_at": { "type": "string" },
          "description": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "raw_report_path": { "type": "string" },
    "command": { "type": "string" },
    "error": { "type": "string" }
  }
}
