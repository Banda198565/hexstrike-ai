{
  "server": "web3_audit_mcp",
  "version": "1.0.0",
  "non_emulation": true,
  "read_only": true,
  "credential_policy": "All API keys and RPC credentials in MCP server env (mcp.json). Never in agent prompts.",
  "blocks": {
    "StaticAnalysis": [
      "parse_contract",
      "slither_run_detectors",
      "slither_structure",
      "slither_find_critical_sinks",
      "check_swc_patterns",
      "aderyn_analyze",
      "mythril_scan_summary",
      "mythx_deep_scan",
      "echidna_run_tests",
      "web3_antivirus_scan",
      "contract_security_score",
      "compile_and_abi",
      "generate_audit_report_skeleton"
    ],
    "TransactionRisk": [
      "forta_get_alerts",
      "forta_stream_threats",
      "goplus_contract_risk",
      "scamsniffer_tx_risk",
      "pocket_universe_simulate",
      "kerberus_url_or_tx_risk"
    ],
    "WalletHygiene": ["revoke_list_approvals"],
    "RPCInfra": [
      "detect_rpc_config",
      "rpc_contract_audit",
      "rpc_tx_trace",
      "rpc_wallet_risk",
      "rpc_event_intel",
      "onchain_metadata",
      "chainstack_rpc_call",
      "chainstack_indexer_query",
      "docs_search",
      "tenderly_simulate",
      "alchemy_get_nft_metadata",
      "infura_get_logs"
    ],
    "Composite": [
      "detect_web3_audit_stack",
      "full_web3_audit",
      "normalize_findings",
      "audit_reports_fetch"
    ]
  },
  "recommended_agent_workflow": [
    "detect_web3_audit_stack",
    "parse_contract OR rpc_contract_audit",
    "slither_run_detectors + check_swc_patterns + goplus_contract_risk",
    "forta_get_alerts + rpc_wallet_risk (if address)",
    "rpc_tx_trace (if tx_hash)",
    "normalize_findings",
    "generate_audit_report_skeleton"
  ],
  "env_vars": {
    "WEB3_RPC_URL": "Primary RPC base URL",
    "WEB3_RPC_KEY": "RPC API key (appended to URL)",
    "FORTA_API_KEY": "Forta Network alerts",
    "MYTHX_API_KEY": "MythX cloud deep scan",
    "TENDERLY_ACCESS_KEY": "Tenderly simulation",
    "TENDERLY_ACCOUNT": "Tenderly account slug",
    "TENDERLY_PROJECT": "Tenderly project slug",
    "ALCHEMY_API_KEY": "Alchemy NFT/metadata",
    "SCAMSNIFFER_API_KEY": "ScamSniffer tx risk",
    "POCKET_UNIVERSE_API_KEY": "Pocket Universe simulate",
    "KERBERUS_API_KEY": "Kerberus URL/tx risk",
    "WEB3_ANTIVIRUS_API_KEY": "Web3 Antivirus ML scan",
    "CHAINSTACK_RPC_URL": "Chainstack JSON-RPC",
    "CHAINSTACK_INDEXER_URL": "Chainstack indexer GraphQL",
    "AUDIT_REPORTS_API_KEY": "Optional audit report search"
  },
  "tools": [
    {"name": "detect_web3_audit_stack", "block": "Composite"},
    {"name": "full_web3_audit", "block": "Composite"},
    {"name": "normalize_findings", "block": "Composite"},
    {"name": "audit_reports_fetch", "block": "Composite"},
    {"name": "parse_contract", "block": "StaticAnalysis"},
    {"name": "slither_run_detectors", "block": "StaticAnalysis"},
    {"name": "slither_structure", "block": "StaticAnalysis"},
    {"name": "slither_find_critical_sinks", "block": "StaticAnalysis"},
    {"name": "check_swc_patterns", "block": "StaticAnalysis"},
    {"name": "aderyn_analyze", "block": "StaticAnalysis"},
    {"name": "mythril_scan_summary", "block": "StaticAnalysis"},
    {"name": "mythx_deep_scan", "block": "StaticAnalysis", "requires_env": ["MYTHX_API_KEY"]},
    {"name": "echidna_run_tests", "block": "StaticAnalysis", "requires_binary": "echidna-test"},
    {"name": "web3_antivirus_scan", "block": "StaticAnalysis", "requires_env": ["WEB3_ANTIVIRUS_API_KEY"]},
    {"name": "contract_security_score", "block": "StaticAnalysis"},
    {"name": "compile_and_abi", "block": "StaticAnalysis"},
    {"name": "generate_audit_report_skeleton", "block": "StaticAnalysis"},
    {"name": "forta_get_alerts", "block": "TransactionRisk", "requires_env": ["FORTA_API_KEY"]},
    {"name": "forta_stream_threats", "block": "TransactionRisk", "requires_env": ["FORTA_API_KEY"]},
    {"name": "goplus_contract_risk", "block": "TransactionRisk", "public_api": true},
    {"name": "scamsniffer_tx_risk", "block": "TransactionRisk", "requires_env": ["SCAMSNIFFER_API_KEY"]},
    {"name": "pocket_universe_simulate", "block": "TransactionRisk", "requires_env": ["POCKET_UNIVERSE_API_KEY"]},
    {"name": "kerberus_url_or_tx_risk", "block": "TransactionRisk", "requires_env": ["KERBERUS_API_KEY"]},
    {"name": "revoke_list_approvals", "block": "WalletHygiene", "read_only": true},
    {"name": "detect_rpc_config", "block": "RPCInfra"},
    {"name": "rpc_contract_audit", "block": "RPCInfra"},
    {"name": "rpc_tx_trace", "block": "RPCInfra"},
    {"name": "rpc_wallet_risk", "block": "RPCInfra"},
    {"name": "rpc_event_intel", "block": "RPCInfra"},
    {"name": "onchain_metadata", "block": "RPCInfra"},
    {"name": "chainstack_rpc_call", "block": "RPCInfra"},
    {"name": "chainstack_indexer_query", "block": "RPCInfra", "requires_env": ["CHAINSTACK_INDEXER_URL"]},
    {"name": "docs_search", "block": "RPCInfra"},
    {"name": "tenderly_simulate", "block": "RPCInfra", "requires_env": ["TENDERLY_ACCESS_KEY", "TENDERLY_ACCOUNT", "TENDERLY_PROJECT"]},
    {"name": "alchemy_get_nft_metadata", "block": "RPCInfra", "requires_env": ["ALCHEMY_API_KEY"]},
    {"name": "infura_get_logs", "block": "RPCInfra"}
  ],
  "finding_schema": {
    "id": "string",
    "source": "string",
    "category": "string",
    "severity": "low|medium|high|critical|info",
    "description": "string",
    "links": "string[]",
    "locations": "object[]"
  }
}
