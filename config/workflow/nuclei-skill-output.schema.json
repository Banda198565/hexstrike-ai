{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hexstrike://nuclei-skill-output/v1",
  "title": "NucleiSkillBuilderOutput",
  "type": "object",
  "required": ["skill_name", "description", "input_schema", "output_schema"],
  "properties": {
    "skill_name": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,64}$" },
    "description": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "source_scan_id": { "type": "string" },
    "input_schema": { "type": "object" },
    "output_schema": { "type": "object" },
    "interesting_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "template_id": { "type": "string" },
          "name": { "type": "string" },
          "severity": { "type": "string" },
          "host": { "type": "string" },
          "location": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "type": { "type": "string" },
          "description": { "type": "string" },
          "exploitability_hint": { "type": "string" }
        }
      }
    },
    "workflow_hint": {
      "type": "object",
      "properties": {
        "next_phase": { "type": "string" },
        "candidate_exploit_skills": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
