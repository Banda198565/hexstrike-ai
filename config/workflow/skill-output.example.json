{
  "skill_name": "web_initial_access_sqli_chain",
  "description": "Recon → HTTP vuln scan → SQLi exploit → admin session — parameterized web initial access chain",
  "tags": ["web", "initial_access", "sql_injection", "chain"],
  "source_attack_id": "atk-2026-07-18-001",
  "input_schema": {
    "type": "object",
    "required": ["target_url"],
    "properties": {
      "target_url": {
        "type": "string",
        "description": "Base URL of target web application, e.g. https://example.com"
      },
      "target_ip": {
        "type": "string",
        "description": "Target IP if known",
        "nullable": true
      },
      "scan_profile": {
        "type": "string",
        "description": "Port/service scan profile",
        "default": "tcp_service_version"
      },
      "dbms_type": {
        "type": "string",
        "description": "DBMS type (mysql, postgres, ...)",
        "default": "mysql"
      }
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "success": { "type": "boolean" },
      "impact": { "type": "string", "description": "Achieved access type" },
      "artifacts": {
        "type": "object",
        "description": "Paths to loot dumps, sessions in orchestrator store"
      }
    }
  },
  "steps": [
    {
      "id": 1,
      "phase": "recon",
      "mcp_tool": "pentest_nmap_scan",
      "description": "Port and service scan",
      "inputs_from": { "skill_input": ["target_ip", "scan_profile"] },
      "expected_output": { "services": "HTTP/HTTPS services for next step" },
      "next_step_condition": "if HTTP/HTTPS found → step 2; else success=false"
    },
    {
      "id": 2,
      "phase": "vuln_scan",
      "mcp_tool": "pentest_http_vuln_scan",
      "description": "HTTP vulnerability scan for SQLi",
      "inputs_from": { "skill_input": ["target_url"], "previous_step_output": ["services"] },
      "expected_output": { "findings": "confirmed SQL injection" },
      "next_step_condition": "if SQLi found → step 3"
    },
    {
      "id": 3,
      "phase": "exploit",
      "mcp_tool": "pentest_sql_injection_exploit",
      "description": "Exploit SQLi to extract users table",
      "inputs_from": { "skill_input": ["dbms_type", "target_url"], "previous_step_output": ["findings"] },
      "expected_output": { "extracted_data": "users table preview" },
      "next_step_condition": "if users extracted → step 4"
    },
    {
      "id": 4,
      "phase": "post_exploitation",
      "mcp_tool": "pentest_web_session_hijack",
      "description": "Obtain privileged web session from extracted creds",
      "inputs_from": { "previous_step_output": ["extracted_data"] },
      "expected_output": { "session_cookie": "valid session", "privilege_level": "admin" },
      "next_step_condition": "finish success=true impact=initial_access_admin_web"
    }
  ]
}
