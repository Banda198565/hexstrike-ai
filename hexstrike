#!/usr/bin/env bash
# HexStrike unified CLI
#   hexstrike sync --mcp
#   hexstrike agent run transaction --mode=dry-run
#   hexstrike agent run discovery --trace
#   hexstrike logs transaction_agent --tail=100
#   hexstrike orchestrator reload
#   hexstrike tx build --target=0xTARGET --value=0.001bnb --gas=21000
#   hexstrike tx sign raw_tx.json --module=KeyVaultSigner
#   hexstrike tx broadcast signed_tx.json
#   hexstrike tx status 0xHASH --json
#   hexstrike tx rescue --target=$GAS_HOLDER_ADDRESS --value=0.01bnb
#   hexstrike mcp tx build ...  (alias layer)
#   hexstrike ops [--quick|--standard|--full]
#   hexstrike fastmcp verify --target 0xPAYROLL [--run-dry-run]
#   hexstrike fastmcp live --target 0xPAYROLL [--dry-run|--live]
ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
if [[ "${1:-}" == "sync" ]]; then shift; exec python3 "$ROOT/scripts/hexstrike_sync.py" "$@"; fi
if [[ "${1:-}" == "tx" ]]; then shift; exec python3 "$ROOT/scripts/hexstrike_tx.py" "$@"; fi
if [[ "${1:-}" == "vault" ]]; then shift; exec python3 "$ROOT/scripts/hexstrike_vault.py" "$@"; fi
if [[ "${1:-}" == "ops" ]]; then
  shift
  exec bash "$ROOT/scripts/vps-fastmcp-ops.sh" "${1:---standard}"
fi
if [[ "${1:-}" == "fastmcp" ]]; then
  shift
  case "${1:-}" in
    verify)
      shift
      exec bash "$ROOT/scripts/fastmcp_verify.sh" "$@"
      ;;
    status)
      shift
      exec bash "$ROOT/scripts/fastmcp_status.sh" "$@"
      ;;
    live|cycle)
      shift
      if [[ -x "$ROOT/scripts/mac-fastmcp-live.sh" ]] && [[ "$(uname -s)" == "Darwin" || "${FORCE_MAC_LIVE:-}" == "1" ]]; then
        exec bash "$ROOT/scripts/mac-fastmcp-live.sh" "$@"
      fi
      exec bash "$ROOT/scripts/fastmcp_live_cycle.sh" "$@"
      ;;
    gate|security-gate)
      shift
      exec bash "$ROOT/scripts/security_gate.sh" "$@"
      ;;
    pull-ops)
      shift
      exec bash "$ROOT/scripts/vps-pull-and-ops.sh" "${1:---standard}"
      ;;
    *)
      echo "Usage: hexstrike fastmcp {status|verify|live|cycle|gate|pull-ops} [args...]" >&2
      exit 1
      ;;
  esac
fi
if [[ "${1:-}" == "mcp" ]]; then
  shift
  if [[ "${1:-}" == "tx" ]]; then shift; exec python3 "$ROOT/scripts/mcp_tx.py" "$@"; fi
  echo "Usage: hexstrike mcp tx {build|sign|broadcast|status|rescue|log|discovery}" >&2
  exit 1
fi
if [[ "${1:-}" == "agent" ]]; then shift; exec python3 "$ROOT/scripts/hexstrike_agent_run.py" "$@"; fi
if [[ "${1:-}" == "logs" ]]; then shift; exec python3 "$ROOT/scripts/hexstrike_logs.py" "$@"; fi
if [[ "${1:-}" == "orchestrator" ]]; then shift; exec python3 "$ROOT/scripts/hexstrike_orchestrator_cmd.py" "$@"; fi
if [[ -x /usr/local/bin/hx && "${1:-}" != "" ]]; then exec /usr/local/bin/hx "$@"; fi
exec python3 "$ROOT/hexstrike_cli.py" "$@"
