#!/usr/bin/env bash
# HexStrike unified CLI
#   hexstrike tx send 0xTARGET --value 0.001bnb --dry-run
#   hexstrike tx sign raw_tx.json --debug
#   hexstrike tx broadcast signed_tx.json --force
#   hexstrike tx status 0xHASH --json
ROOT="$(cd "$(dirname "$0")" && pwd)"
if [[ "${1:-}" == "tx" ]]; then
  shift
  exec python3 "$ROOT/scripts/hexstrike_tx.py" "$@"
fi
if [[ -x /usr/local/bin/hx && "${1:-}" != "" ]]; then
  exec /usr/local/bin/hx "$@"
fi
exec python3 "$ROOT/hexstrike_cli.py" "$@"
