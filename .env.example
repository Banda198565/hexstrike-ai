# HexStrike API security — copy to .env and set a strong random key
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
HEXSTRIKE_API_KEY=change-me-to-a-long-random-secret

# Local LLM (Ollama) — Cursor integration
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_ORIGINS=*
# Public tunnel URL for Cursor cloud backend — must end with /v1
# OLLAMA_PUBLIC_BASE_URL=https://your-tunnel.trycloudflare.com/v1
