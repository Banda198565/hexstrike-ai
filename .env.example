# HexStrike API security — copy to .env and set a strong random key
HEXSTRIKE_API_KEY=change-me-to-a-long-random-secret

# RAG (Eva HDD)
RAG_STORAGE_ROOT=/Volumes/Eva/hexstrike-rag-data
RAG_STORAGE_PATH=/Volumes/Eva/hexstrike-rag-data
DB_TYPE=lancedb
RAG_BATCH_SIZE=16
RAG_NUM_WORKERS=4

# Local LLM — 16GB RAM profile
# Use deepseek-r1:1.5b only (~1.1GB). Avoid 7b+ on 16GB machines.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_BYPASS_TUNNEL=true
OLLAMA_PUBLIC_BASE_URL=http://127.0.0.1:11434/v1
LLM_PROVIDER=ollama-local
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=deepseek-r1:1.5b
CURSOR_INTEGRATION_MODE=OFFLINE_PRIMARY
OLLAMA_NUM_THREAD=4
OLLAMA_NUM_PREDICT=128
OLLAMA_NUM_CTX=4096
