# OSINT providers (hexstrike-osint-agent)
ARKHAM_API_KEY=
SHODAN_API_KEY=
GETBLOCK_API_KEY=

# Monitoring targets (optional overrides)
WALLET_TARGET=0x730ea0231808f42a20f8921ba7fbc788226768f5
IP_TARGET=51.250.97.223
WALLET_INTERVAL=15s
IP_INTERVAL=30s

# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
HEXSTRIKE_API_KEY=change-me-to-a-long-random-secret

# Local LLM (Ollama) — Cursor System Integration Mode
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_ORIGINS=*
OLLAMA_BYPASS_TUNNEL=true
OLLAMA_PUBLIC_BASE_URL=http://127.0.0.1:11434/v1
LLM_PROVIDER=ollama-local
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=deepseek-r1:1.5b
CURSOR_INTEGRATION_MODE=OFFLINE_PRIMARY
# deepseek-r1:1.5b — fast local default (iMac 32GB)
OLLAMA_NUM_THREAD=16
OLLAMA_NUM_PREDICT=256
# Cloud tunnel fallback (only if localhost unreachable from Cursor cloud):
# OLLAMA_PUBLIC_BASE_URL=https://your-tunnel.trycloudflare.com/v1
# OLLAMA_BYPASS_TUNNEL=false
