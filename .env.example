# OSINT providers (hexstrike-osint-agent / Samson bulk-audit)
# Prefer SAMSON_ARKHAM_API_KEY in docker-compose; ARKHAM_API_KEY is also accepted.
SAMSON_ARKHAM_API_KEY=
ARKHAM_API_KEY=
SAMSON_FOFA_API_KEY=
FOFA_API_KEY=
SAMSON_FOFA_API_EMAIL=
FOFA_EMAIL=
SAMSON_COINSTATS_API_KEY=
COINSTATS_API_KEY=
SHODAN_API_KEY=
GETBLOCK_API_KEY=
GITHUB_TOKEN=

# Block explorer APIs (Etherscan API V2 — replaces deprecated BscScan V1)
# Create key: https://etherscan.io/myapikey  (same key works for BSC via chainid=56)
# Docs: https://docs.etherscan.io/v2-migration
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=

# Redis (VPS local / Mac tunnel). Prefer SSH tunnel over exposing 6379.
# Mac→VPS tunnel: ssh hexstrike-vps -L 6380:127.0.0.1:6379 -N -f
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# BSC RPC (auto-set by scripts/vps-setup-env.sh when GETBLOCK_API_KEY present)
# BSC_RPC=https://go.getblock.io/YOUR_GETBLOCK_KEY/
# BSC_RPC=http://51.222.42.220:8545
# BSCSCAN_API_KEY=your_bscscan_key
# ETHERSCAN_API_KEY=${BSCSCAN_API_KEY}

# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
HEXSTRIKE_API_KEY=change-me-to-a-long-random-secret

# Local LLM — llama-server (:8080) PRIMARY, Ollama (:11434) fallback
# Auto-detect: bash scripts/connect-llm-orchestrator.sh
# CLI: python3 hexstrike_cli.py llm {connect|status|handshake}
LLAMA_SERVER_HOST=http://127.0.0.1:8080
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_ORIGINS=*
OLLAMA_BYPASS_TUNNEL=true
# Comma list — first reachable wins (unless LLM_PROVIDER / LLM_BASE_URL forced)
LLM_PROVIDER_PRIORITY=llama-server,ollama-local
# Leave LLM_PROVIDER / LLM_BASE_URL empty for auto; or force e.g. llama-server / ollama-local
LLM_PROVIDER=
LLM_BASE_URL=
LLM_MODEL=deepseek-r1:1.5b
# Tunnel URL only (do not set to localhost — connect preserves this key)
OLLAMA_PUBLIC_BASE_URL=
CURSOR_INTEGRATION_MODE=OFFLINE_PRIMARY
# Defense-only system prompt prepended to every skill/chat call
# LLM_SYSTEM_PROMPT_PATH=config/llm-system-prompt.md
# deepseek-r1:1.5b — fast local default; or qwen2.5-coder:7b on 16GB+
OLLAMA_NUM_THREAD=16
OLLAMA_NUM_PREDICT=512
OLLAMA_NUM_CTX=32768

# Ollama Cloud — local offload via signed-in daemon (no GPU required for large models)
# LLM_PROVIDER=ollama-local-cloud
# OLLAMA_MODEL=qwen3-coder:480b-cloud
# Run once: ollama signin && ollama pull qwen3-coder:480b-cloud

# Ollama Cloud — direct ollama.com API (create key at https://ollama.com/settings/keys)
# LLM_PROVIDER=ollama-cloud
# OLLAMA_HOST=https://ollama.com
# OLLAMA_API_KEY=your_api_key
# OLLAMA_CLOUD_MODEL=qwen3.5:397b

# Remote tunnel fallback (if localhost LLM unreachable from remote host):
# OLLAMA_PUBLIC_BASE_URL=https://your-tunnel.trycloudflare.com/v1
# OLLAMA_BYPASS_TUNNEL=false

# --- Cloud DeepSeek R1 (Reasoning Agent — plan only, no execution) ---
# OpenRouter (free tier): https://openrouter.ai/deepseek/deepseek-r1:free
# R1_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# R1_MODEL=deepseek/deepseek-r1:free
# R1_BASE_URL=https://openrouter.ai/api/v1

# DeepSeek official API: https://api.deepseek.com
# R1_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...
# R1_MODEL=deepseek-reasoner
# R1_BASE_URL=https://api.deepseek.com/v1

# Azure Foundry / custom OpenAI-compatible endpoint:
# R1_PROVIDER=custom
# R1_API_KEY=...
# R1_BASE_URL=https://your-endpoint.openai.azure.com/v1
# R1_MODEL=DeepSeek-R1

# R1_TIMEOUT_SEC=180
# R1_SITE_URL=https://your-project.example   # OpenRouter HTTP-Referer (optional)
# R1_SITE_NAME=HexStrike                     # OpenRouter X-Title (optional)
