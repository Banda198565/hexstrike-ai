# =============================================================================
# MAINNET ENV — BSC production (copy to mainnet.env, gitignored)
#
#   cp scripts/sandbox/mainnet.env.example scripts/sandbox/mainnet.env
#   # paste BOT_PRIVATE_KEY (or AGENT_PRIVATE_KEY) locally — NEVER commit
#
# ARCHITECTURE — External Funder (no Target private key):
#   TARGET (watch only)     0x96B23C4680E1a37cE17730e6118D0C9223e72A66  — NO PRIVATE KEY
#   BOT (signer + gas)      0x85dB346BE1d9d5D8ec4F57acf0067FbE53a6E846  — ONLY KEY NEEDED
#   SAFE (evacuation)       0x060447dC91dfb22A5233731aF67E9E8dafdF24d1  — receive only
#
# Flow: poll TARGET balance → BOT signs EIP-1559 rescue → Puissant/public → SAFE
# =============================================================================

# --- BSC RPC ---
CHAIN_ID=56
RPC_URL=https://bsc-dataseed.binance.org
DIRECT_RPC_URL=https://bsc-dataseed.binance.org
RELAY_PUBLIC_RPC=https://bsc-dataseed.binance.org

# --- Puissant (BSC private relay) ---
PUISSANT_BUILDER_URL=https://puissant-builder.48.club/
PUISSANT_EXPLORE_URL=https://explore.48.club/v2/bundle

# --- Wallet roles (FINAL) ---
# ⚠️  NEVER ask for / store Target private key — watch-only address.

# 1) Бот-разведчик — единственный ключ; спонсор газа + подпись (0.015 BNB)
BOT_ADDRESS=0x85dB346BE1d9d5D8ec4F57acf0067FbE53a6E846
BOT_PRIVATE_KEY=
# paste operator key above (no quotes needed). NEVER commit.
# alias (same value as BOT_PRIVATE_KEY):
# AGENT_PRIVATE_KEY=

# 2) Цель — ТОЛЬКО мониторинг (eth_getBalance). Приватник НЕ НУЖЕН.
TARGET_WATCH_ADDRESS=0x96B23C4680E1a37cE17730e6118D0C9223e72A66

# 3) Сейф — allowlist для эвакуации (ALLOWED_FUNDERS + FUNDER_ADDRESS)
FUNDER_ADDRESS=0x060447dC91dfb22A5233731aF67E9E8dafdF24d1
ALLOWED_FUNDERS=0x060447dC91dfb22A5233731aF67E9E8dafdF24d1
ALLOWED_DESTINATIONS=0x060447dC91dfb22A5233731aF67E9E8dafdF24d1
REQUIRE_ALLOWLIST=true

# --- Rescue policy ---
THRESHOLD_WEI=500000000000000000
MIN_GAS_WEI=10000000000000000
RESCUE_VALUE_WEI=1000000000000000
POLL_INTERVAL_SEC=10

# --- Entity gate (fail-closed on mainnet) ---
ARKHAM_API_KEY=
ENTITY_CACHE_TTL_MINUTES=15

# --- LLM async (hot path never waits) ---
LLM_ASYNC_ONLY=1
OLLAMA_HOST=http://127.0.0.1:11434

# --- Safety: start with DRY_RUN until operator confirms ---
DRY_RUN=true
HARDENING_ENABLED=true
GO_LIVE_GATES=true
GO_LIVE_PHASE=shadow
SIGNER_BACKEND=kms
QUORUM_RPC_URLS=https://bsc-dataseed.binance.org,https://bsc-dataseed1.binance.org,https://bsc-dataseed2.binance.org
QUORUM_MIN_AGREE=2
KILL_SWITCH=false
MAX_RESCUES_PER_WINDOW=3
RESCUE_WINDOW_SEC=3600
COOLDOWN_AFTER_BLOCK_SEC=300
CANARY_MAX_VALUE_WEI=1000000000000000
LIMITED_MAX_VALUE_WEI=10000000000000000
MAX_BALANCE_DELTA_WEI=0
ANOMALY_STALE_TIMEOUT_SEC=120
GUARD_RPC_TIMEOUT_SEC=10
