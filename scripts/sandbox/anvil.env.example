# Copy to anvil.env and adjust if needed.
# Anvil ships with 10 funded test accounts — keys are public, local-only.

RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337

# Account #1 — watched "bot" wallet (Anvil default mnemonic)
BOT_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
BOT_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b774b828

# Account #0 — funder / rescue destination
FUNDER_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# Trigger rescue when balance drops below this (wei). Default ≈ 0.5 ETH
THRESHOLD_WEI=500000000000000000

# Must keep at least this much wei to pay gas for the rescue tx
MIN_GAS_WEI=10000000000000000

# Rescue tx sends this much wei to FUNDER (simulated "refill request" ping)
RESCUE_VALUE_WEI=1000000000000000

POLL_INTERVAL_SEC=10
