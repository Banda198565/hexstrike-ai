# =============================================================================
# SANDBOX ENV TEMPLATE — copy to anvil.env (gitignored) before running.
#
# These keys are Anvil public test keys. Do not use in production.
# Quick setup: ./scripts/sandbox/setup-anvil-env.sh
# =============================================================================

# Bot RPC endpoint — Step 1: direct Anvil; Step 2/3: proxy (8546)
RPC_URL=http://127.0.0.1:8545
UPSTREAM_RPC=http://127.0.0.1:8545
PROXY_PORT=8546
CHAIN_ID=31337

# Anvil default mnemonic — replace via setup-anvil-env.sh or paste from `cast wallet list`
BOT_ADDRESS=<ANVIL_TEST_ADDRESS>
BOT_PRIVATE_KEY=<ANVIL_TEST_KEY — DO NOT USE IN PROD>
FUNDER_ADDRESS=<ANVIL_FUNDER_ADDRESS>

# Trigger rescue when balance drops below this (wei). Default ≈ 0.5 ETH
THRESHOLD_WEI=500000000000000000

# Must keep at least this much wei to pay gas for the rescue tx
MIN_GAS_WEI=10000000000000000

# Rescue tx sends this much wei to FUNDER (simulated "refill request" ping)
RESCUE_VALUE_WEI=1000000000000000

POLL_INTERVAL_SEC=10

# Step 3 defensive hardening (multi-RPC + anomaly guard)
HARDENING_ENABLED=false
DIRECT_RPC_URL=http://127.0.0.1:8545
