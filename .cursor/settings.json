{
  "$schema": "https://cursor.com/schemas/settings.json",
  "_comment": "System Integration Mode \u2014 localhost-first, OFFLINE_PRIMARY for reasoning",
  "systemIntegrationMode": "OFFLINE_PRIMARY",
  "AUTHORIZED_OPERATOR_MODE": false,
  "ollama": {
    "host": "http://127.0.0.1:11434",
    "model": "deepseek-r1:1.5b",
    "openai_compatible_base": "http://127.0.0.1:11434/v1",
    "api_key_placeholder": "ollama"
  },
  "cursor": {
    "chat": {
      "defaultModel": "deepseek-r1:1.5b",
      "useLocalLlm": true,
      "model_type": "openai_compatible"
    },
    "composer": {
      "defaultModel": "deepseek-r1:1.5b",
      "useLocalLlm": true,
      "model_type": "openai_compatible"
    },
    "maxMode": {
      "defaultModel": "deepseek-r1:1.5b",
      "preferHighReasoning": true,
      "routeToLocal": true,
      "model_type": "openai_compatible"
    },
    "models": {
      "custom": [
        {
          "id": "deepseek-r1:1.5b",
          "name": "deepseek-r1:1.5b",
          "provider": "openai-compatible",
          "model_type": "openai_compatible",
          "baseUrl": "http://127.0.0.1:11434/v1",
          "supportsChainOfThought": true
        }
      ],
      "disabled": []
    },
    "openai": {
      "overrideBaseUrl": true,
      "baseUrl": "http://127.0.0.1:11434/v1",
      "apiKey": "ollama",
      "model_type": "openai_compatible"
    },
    "routing": {
      "preferLocalhost": true,
      "bypassTunnel": true,
      "offlinePrimary": true,
      "tunnelFallback": false
    }
  },
  "env": {
    "OLLAMA_HOST": "http://127.0.0.1:11434",
    "OLLAMA_ORIGINS": "*",
    "OLLAMA_PUBLIC_BASE_URL": "http://127.0.0.1:11434/v1",
    "OLLAMA_BYPASS_TUNNEL": "true",
    "LLM_PROVIDER": "ollama-local",
    "LLM_BASE_URL": "http://127.0.0.1:11434/v1",
    "LLM_MODEL": "deepseek-r1:1.5b",
    "CURSOR_INTEGRATION_MODE": "OFFLINE_PRIMARY"
  }
}
