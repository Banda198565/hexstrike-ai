{
  "version": "1",
  "description": "HexStrike custom agent registry (orchestrator-compatible)",
  "defaults": {
    "server": "http://127.0.0.1:8888",
    "artifacts_dir": "artifacts",
    "mode": "authorized_lab"
  },
  "agents": {
    "Agent-Orchestrator": {
      "role": "orchestrator",
      "description": "Routes tasks via hexstrike-orchestrator (not Cursor chat)",
      "runner": "scripts/hexstrike-orchestrator.py",
      "cli": "./hexstrike-orchestrator",
      "tasks": {
        "dispatch": {
          "note": "Use: hexstrike-orchestrator run <workflow> | dispatch <agent> <task> | watch"
        }
      },
      "workflows_file": "agents/workflows.json",
      "queue_dir": "agents/queue",
      "log_dir": "artifacts/orchestrator",
      "delegates_to": [
        "Agent-OSINT-03",
        "Agent-Web-04",
        "Agent-Graph-01",
        "Agent-Infra-01",
        "Agent-Contract-02",
        "Agent-Vuln-05",
        "Agent-Report-06",
        "Agent-Battle-07"
      ]
    },
    "Agent-OSINT-03": {
      "role": "off-chain-intel",
      "description": "Passive on-chain → off-chain infra mapping (no active scan)",
      "tasks": {
        "infra-mapping": {
          "script": "scripts/agents/agent_osint_03.py",
          "output": "artifacts/infra-targets.json",
          "methods": ["github_dorking", "ens_resolve", "metadata_extract", "ip_history"],
          "constraints": ["read-only", "passive", "no-nmap"]
        },
        "entity-resolution": {
          "script": "scripts/agents/agent_osint_03_entity.py",
          "output": "artifacts/entity-id.json",
          "methods": ["arkham_intelligence", "first_funder_analysis", "bscan_labels", "github_org_mapping"],
          "constraints": ["read-only", "passive"]
        },
        "blockscan-cluster": {
          "script": "scripts/agents/agent_osint_03_multichain.py",
          "output": "artifacts/multichain-cluster.json",
          "methods": ["blockscan_multichain", "basescan_portfolio", "bsc_outflow_sample"],
          "constraints": ["read-only", "passive"]
        }
      },
      "mcp_tools": [],
      "hexstrike_api": []
    },
    "Agent-Web-04": {
      "role": "web-recon",
      "description": "Stealth service fingerprinting — headers/cookies only, LotL",
      "tasks": {
        "stealth-recon": {
          "script": "scripts/agents/agent_web_04.py",
          "input": "artifacts/infra-targets.json",
          "output": "artifacts/web-recon.json",
          "focus": ["jenkins_fingerprint", "api_surface", "git_exposure_passive"],
          "constraints": ["lotl-mode", "no-nmap", "no-exploit", "no-bruteforce"]
        }
      },
      "mcp_tools": ["technology_detection"],
      "hexstrike_api": ["/api/intelligence/technology-detection"]
    },
    "Agent-Graph-01": {
      "role": "on-chain-graph",
      "description": "USDT graph + token verification via blockchain MCP",
      "tasks": {
        "bind-mcp-tools": {
          "script": "scripts/mcp-smoke-test.sh",
          "config": "mcp/agent-bindings.json",
          "target": "0x4943F5E7F4e450d48Ae82026163ecDe8A52C53dA"
        },
        "onchain-graph": {
          "output": "artifacts/hot-wallet-onchain-graph.json",
          "note": "Use block-explorer-mcp: get_token_transfers, address_graph_summary"
        }
      },
      "mcp_servers": ["block-explorer-mcp", "defi-dex-mcp", "evm-rpc-mcp"]
    },
    "Agent-Infra-01": {
      "role": "mcp-deploy",
      "description": "Deploy read-only blockchain MCP layer on VPS",
      "tasks": {
        "deploy-mcp": {
          "script": "scripts/deploy-blockchain-mcp.sh",
          "servers": ["evm-rpc-mcp", "block-explorer-mcp", "defi-dex-mcp", "mev-offensive-mcp"],
          "config": "mcp-config.json"
        }
      }
    },
    "Agent-Contract-02": {
      "role": "contract-audit",
      "description": "Read-only bytecode / EIP-7702 analysis",
      "tasks": {
        "fetch-bytecode": {
          "output": "artifacts/authority-contract-analysis.json",
          "mcp_tools": ["get_contract_code", "get_contract_abi_stub", "eth_call_read"]
        }
      },
      "mcp_servers": ["evm-rpc-mcp", "block-explorer-mcp"]
    },
    "Agent-Vuln-05": {
      "role": "vuln-intel",
      "description": "Passive CVE correlation — no exploit",
      "tasks": {
        "passive-cve-check": {
          "script": "scripts/agents/agent_vuln_05.py",
          "output": "artifacts/jenkins-cve-report.json",
          "sources": ["cve.mitre.org", "nvd.nist.gov", "jenkins-security-advisories"],
          "constraints": ["no-exploit", "read-only"]
        }
      }
    },
    "Agent-Battle-07": {
      "role": "sandbox-redteam",
      "description": "Autonomous Go agent — 13-attack battle suite (01-13) + offensive MEV stress",
      "tasks": {
        "battle-suite": {
          "script": "scripts/sandbox/run-battle-suite.sh",
          "output": "artifacts/sandbox/battle-report.json",
          "constraints": ["local-anvil-only", "authorized-lab", "no-remote-exploit"]
        },
        "generate-target-profile": {
          "script": "scripts/sandbox/generate-target-profile.py",
          "output": "artifacts/sandbox/target-profiles.json",
          "constraints": ["read-only"]
        },
        "multi-wallet-recon": {
          "script": "scripts/sandbox/run-multi-wallet-recon.py",
          "output": "artifacts/sandbox/target-recon-bundle.json",
          "constraints": ["read-only", "no-remote-exploit"]
        },
        "generate-target-conclusion": {
          "script": "scripts/sandbox/generate-target-conclusion.py",
          "output": "artifacts/sandbox/target-conclusion.json",
          "constraints": ["read-only"]
        },
        "redteam-all": {
          "script": "scripts/sandbox/redteam/run-all.sh",
          "output": "artifacts/sandbox/redteam-report.json",
          "constraints": ["local-anvil-only"]
        },
        "target-recon": {
          "script": "scripts/sandbox/run-target-recon.sh",
          "output": "artifacts/sandbox/target-recon-bundle.json",
          "input": "artifacts/sandbox/target-profiles.json",
          "constraints": ["read-only", "no-remote-exploit"]
        },
        "target-fork-setup": {
          "script": "scripts/sandbox/setup-real-target-fork.sh",
          "output": "artifacts/sandbox/target-fork-status.json",
          "constraints": ["local-fork-only"]
        }
      },
      "cli": "./bin/hexstrike-agent",
      "depends_on": ["foundry", "python3"]
    },
    "Agent-MEV-Offensive": {
      "role": "mev-offensive",
      "description": "Read-only MEV offensive pipeline — live mempool, fork PnL, builder dry-run",
      "tasks": {
        "live-mempool-scan": {
          "script": "scripts/sandbox/mev/mempool_live.py",
          "output": "artifacts/sandbox/mev-live-mempool-scan.json",
          "mcp_tools": ["scan_live_mempool_tool"],
          "constraints": ["read-only", "MEV_SANDBOX_ONLY=1", "no-mainnet-submit"]
        },
        "offensive-pipeline": {
          "script": "scripts/sandbox/mev/offensive_pipeline.py",
          "output": "artifacts/sandbox/mev-live-pipeline-result.json",
          "mcp_tools": ["run_offensive_pipeline_tool"],
          "constraints": ["read-only", "BUILDER_SIM_ONLY=1"]
        },
        "builder-sim": {
          "script": "scripts/sandbox/mev/builder_sim.py",
          "output": "artifacts/sandbox/mev-builder-sim.json",
          "mcp_tools": ["builder_sim_dry_run"],
          "constraints": ["simulation-only", "would_submit=false"]
        },
        "mev-stress": {
          "script": "scripts/sandbox/run-mev-live-stress.sh",
          "output": "artifacts/sandbox/mev-live-stress-report.json",
          "constraints": ["sandbox-only"]
        }
      },
      "mcp_servers": ["mev-offensive-mcp", "evm-rpc-mcp", "defi-dex-mcp"],
      "cli": "./bin/hexstrike-agent mev live",
      "depends_on": ["foundry", "python3", "fastmcp"]
    },
    "Agent-Report-06": {
      "role": "reporting",
      "description": "Defensive audit checklist for responsible disclosure",
      "tasks": {
        "generate-defensive-checklist": {
          "script": "scripts/agents/agent_report_06.py",
          "output": "artifacts/defensive-audit-template.md",
          "include": ["hardening", "access-control", "secret-management"]
        },
        "operator-balance-check": {
          "script": "scripts/agents/agent_operator_balance.py",
          "output": "artifacts/operator-balance.json",
          "constraints": ["read-only", "no-exchange-access"]
        },
        "operator-crypto-audit": {
          "script": "scripts/crypto-audit.sh",
          "output": "artifacts/operator-crypto-audit.txt",
          "constraints": ["local-only", "no-secret-dump", "mac-operator-lab"]
        },
        "generate-vps-master-report": {
          "script": "scripts/agents/agent_report_vps_master.py",
          "output": "artifacts/vps-master-report.json",
          "include": ["all-artifacts", "orchestrator-latest", "highlights"]
        }
      }
    }
  }
}
