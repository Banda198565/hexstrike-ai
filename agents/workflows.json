    "operator-targets-3progon": {
      "description": "3 прогона (часть 1+2): operator-lab + field-targets-5 + сводный отчёт RU",
      "mode": "forensics",
      "env": {
        "WALLETS_FILE": "scripts/sandbox/field-targets-5.json",
        "WALLETS_ONLY": "1"
