      "description": "EIP-2612 permit farming analysis + analyzer + report",
      "mode": "forensics",
      "steps": [
        {"agent": "Agent-Contract-03", "task": "permit-farming-analyze"},
        {"agent": "Agent-Forensics-01", "task": "run-analyzer-permit", "depends_on": "permit-farming-analyze"},
        {"agent": "Agent-Report-06", "task": "generate-vps-master-report", "depends_on": "run-analyzer-permit"}
      ]
    },
    "create2-forensics": {
      "description": "CREATE2 / EIP-1167 factory pipeline analysis + master report",
      "mode": "forensics",
      "steps": [
        {"agent": "Agent-Contract-04", "task": "create2-analyze"},
        {"agent": "Agent-Forensics-01", "task": "run-analyzer-create2", "depends_on": "create2-analyze"},
        {"agent": "Agent-Report-06", "task": "generate-vps-master-report", "depends_on": "run-analyzer-create2"}
