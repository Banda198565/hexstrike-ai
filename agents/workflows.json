{
  "version": "1",
  "description": "Predefined multi-agent workflows for hexstrike-orchestrator",
  "workflows": {
    "operator-lab": {
      "description": "Operator preflight: balance check + crypto audit + checklist",
      "steps": [
        {"agent": "Agent-Report-06", "task": "operator-balance-check"},
        {"agent": "Agent-Report-06", "task": "operator-crypto-audit", "optional": true},
        {"agent": "Agent-Report-06", "task": "generate-defensive-checklist", "optional": true}
      ],
      "note": "Cannot withdraw from Binance — balance step prints exact deposit instructions"
    },
    "entity-id-pipeline": {
      "description": "Passive entity ID: multichain + entity JSON + web fingerprint",
      "steps": [
        {"agent": "Agent-OSINT-03", "task": "blockscan-cluster"},
        {"agent": "Agent-OSINT-03", "task": "entity-resolution", "depends_on": "blockscan-cluster"},
        {"agent": "Agent-Web-04", "task": "stealth-recon", "depends_on": "entity-resolution"}
      ]
    },
    "defensive-disclosure": {
      "description": "CVE report + hardening template for infra owner outreach",
      "steps": [
        {"agent": "Agent-Vuln-05", "task": "passive-cve-check"},
        {"agent": "Agent-Report-06", "task": "generate-defensive-checklist"}
      ]
    },
    "infra-passive": {
      "description": "Infra map only (no web probes)",
      "steps": [
        {"agent": "Agent-OSINT-03", "task": "infra-mapping"}
      ]
    },
    "full-recon-readonly": {
      "description": "Full passive recon chain from phases A–E artifacts",
      "steps": [
        {"agent": "Agent-OSINT-03", "task": "infra-mapping"},
        {"agent": "Agent-OSINT-03", "task": "blockscan-cluster"},
        {"agent": "Agent-OSINT-03", "task": "entity-resolution"},
        {"agent": "Agent-Web-04", "task": "stealth-recon"},
        {"agent": "Agent-Vuln-05", "task": "passive-cve-check"},
        {"agent": "Agent-Report-06", "task": "generate-defensive-checklist"}
      ]
    },
    "field-targets-5": {
      "description": "5 report-selected targets: profile → fork → recon → conclusion",
      "env": {
        "WALLETS_FILE": "scripts/sandbox/field-targets-5.json",
        "WALLETS_ONLY": "1"
      },
      "steps": [
        {"agent": "Agent-Battle-07", "task": "generate-target-profile"},
        {"agent": "Agent-Battle-07", "task": "target-fork-setup", "depends_on": "generate-target-profile"},
        {"agent": "Agent-Battle-07", "task": "multi-wallet-recon", "depends_on": "target-fork-setup"},
        {"agent": "Agent-Battle-07", "task": "generate-target-conclusion", "depends_on": "multi-wallet-recon"},
        {"agent": "Agent-Report-06", "task": "generate-vps-master-report", "depends_on": "generate-target-conclusion"}
      ],
      "note": "Read-only. hot_wallet, authority, hub, puissant, infra_correlated_wallet from desktop reports."
    },
    "field-targets-6": {
      "description": "Sweep contracts cluster: bytecode forensics → fork → recon → conclusion",
      "env": {
        "WALLETS_FILE": "scripts/sandbox/field-targets-6.json",
        "WALLETS_ONLY": "1"
      },
      "steps": [
        {"agent": "Agent-Battle-07", "task": "generate-target-profile"},
        {"agent": "Agent-Battle-07", "task": "target-fork-setup", "depends_on": "generate-target-profile"},
        {"agent": "Agent-Battle-07", "task": "multi-wallet-recon", "depends_on": "target-fork-setup"},
        {"agent": "Agent-Battle-07", "task": "generate-target-conclusion", "depends_on": "multi-wallet-recon"},
        {"agent": "Agent-Report-06", "task": "generate-vps-master-report", "depends_on": "generate-target-conclusion"}
      ],
      "note": "Read-only. sweep routers + EIP-7702 impl + Rhino.fi hub from recon Phase A outflow analysis."
    },
    "sweep-phase-2": {
      "description": "Phase-2: EIP-7702 impl bytecode audit + Rhino.fi hub trace + exchange forensics",
      "steps": [
        {"agent": "Agent-Battle-07", "task": "sweep-phase2-audit"},
        {"agent": "Agent-Report-06", "task": "generate-vps-master-report", "depends_on": "sweep-phase2-audit"}
      ],
      "note": "Read-only. Signature policy audit on impl 0x314C01e7... + hub USDT state + LEA pack."
    },
    "multi-wallet-conclusions": {
      "description": "All seed wallets: profile → fork → multi recon → conclusion report",
      "steps": [
        {"agent": "Agent-Battle-07", "task": "generate-target-profile"},
        {"agent": "Agent-Battle-07", "task": "target-fork-setup", "depends_on": "generate-target-profile"},
        {"agent": "Agent-Battle-07", "task": "multi-wallet-recon", "depends_on": "target-fork-setup"},
        {"agent": "Agent-Battle-07", "task": "generate-target-conclusion", "depends_on": "multi-wallet-recon"},
        {"agent": "Agent-Report-06", "task": "generate-vps-master-report", "depends_on": "generate-target-conclusion"}
      ],
      "note": "Read-only. Scans hot_wallet, authority, hub, operator, top counterparties."
    },
    "real-target-full": {
      "description": "Multi-wallet recon + conclusions + optional local battle",
      "steps": [
        {"agent": "Agent-Battle-07", "task": "generate-target-profile"},
        {"agent": "Agent-Battle-07", "task": "target-fork-setup"},
        {"agent": "Agent-Battle-07", "task": "multi-wallet-recon", "depends_on": "target-fork-setup"},
        {"agent": "Agent-Battle-07", "task": "generate-target-conclusion", "depends_on": "multi-wallet-recon"},
        {"agent": "Agent-Battle-07", "task": "battle-suite", "optional": true},
        {"agent": "Agent-Battle-07", "task": "generate-target-conclusion", "depends_on": "battle-suite", "optional": true},
        {"agent": "Agent-Report-06", "task": "generate-vps-master-report", "depends_on": "generate-target-conclusion"}
      ],
      "note": "Battle step is local dummy Anvil only (optional)."
    },
    "real-target-pipeline": {
      "description": "Legacy single-wallet pipeline (use multi-wallet-conclusions instead)",
      "steps": [
        {"agent": "Agent-Battle-07", "task": "generate-target-profile"},
        {"agent": "Agent-Battle-07", "task": "target-fork-setup", "depends_on": "generate-target-profile"},
        {"agent": "Agent-Battle-07", "task": "multi-wallet-recon", "depends_on": "target-fork-setup"},
        {"agent": "Agent-Battle-07", "task": "generate-target-conclusion", "depends_on": "multi-wallet-recon"},
        {"agent": "Agent-OSINT-03", "task": "entity-resolution", "optional": true},
        {"agent": "Agent-Report-06", "task": "generate-vps-master-report", "optional": true, "depends_on": "generate-target-conclusion"}
      ],
      "note": "Read-only. Upgraded to multi-wallet + conclusion."
    },
    "sandbox-battle": {
      "description": "Local Anvil red-team: 7 attacks + battle-report readiness score",
      "steps": [
        {"agent": "Agent-Battle-07", "task": "battle-suite"},
        {"agent": "Agent-Report-06", "task": "generate-vps-master-report", "optional": true, "depends_on": "battle-suite"}
      ],
      "note": "Requires Foundry (anvil, cast). LOCAL SANDBOX ONLY."
    },
    "dual-mode-defense": {
      "description": "Contract defense audit — Slither, Mythril, Echidna, remediation report",
      "mode": "defense",
      "env": {
        "HEXSTRIKE_MODE": "defense",
        "DUAL_MODE_CONTRACT": "scripts/sandbox/contracts/RevertOnWithdraw.sol"
      },
      "steps": [
        {"agent": "Agent-DualMode-08", "task": "contract-audit-defense"},
        {"agent": "Agent-Report-06", "task": "generate-vps-master-report", "optional": true, "depends_on": "contract-audit-defense"}
      ],
      "note": "Read-only static/dynamic audit. Set DUAL_MODE_CONTRACT for custom target."
    },
    "dual-mode-offense": {
      "description": "Sandbox Foundry PoC — local Anvil only (HEXSTRIKE_SANDBOX=1)",
      "mode": "offense",
      "env": {
        "HEXSTRIKE_MODE": "offense",
        "HEXSTRIKE_SANDBOX": "1",
        "DUAL_MODE_CONTRACT": "scripts/sandbox/contracts/RevertOnWithdraw.sol",
        "DUAL_MODE_POC_TEST": "test/"
      },
      "steps": [
        {"agent": "Agent-DualMode-08", "task": "contract-audit-offense"},
        {"agent": "Agent-Battle-07", "task": "battle-suite", "optional": true},
        {"agent": "Agent-Report-06", "task": "generate-vps-master-report", "optional": true}
      ],
      "note": "PoC simulation in local Foundry sandbox only — never mainnet."
    },
    "dual-mode-full": {
      "description": "Defense audit then optional sandbox offense + battle suite",
      "env": {
        "DUAL_MODE_CONTRACT": "scripts/sandbox/contracts/RevertOnWithdraw.sol",
        "HEXSTRIKE_SANDBOX": "1"
      },
      "steps": [
        {"agent": "Agent-DualMode-08", "task": "contract-audit-defense"},
        {"agent": "Agent-DualMode-08", "task": "contract-audit-offense", "optional": true},
        {"agent": "Agent-Battle-07", "task": "battle-suite", "optional": true}
      ],
      "note": "Blue team first, then optional red-team PoC if Foundry sandbox is available."
    },
    "vps-full-readonly": {
      "description": "VPS end-to-end: full recon + master report (no Mac operator audit)",
      "steps": [
        {"agent": "Agent-OSINT-03", "task": "infra-mapping"},
        {"agent": "Agent-OSINT-03", "task": "blockscan-cluster"},
        {"agent": "Agent-OSINT-03", "task": "entity-resolution"},
        {"agent": "Agent-Web-04", "task": "stealth-recon"},
        {"agent": "Agent-Vuln-05", "task": "passive-cve-check"},
        {"agent": "Agent-Report-06", "task": "generate-defensive-checklist"},
        {"agent": "Agent-Report-06", "task": "generate-vps-master-report"}
      ]
    },
